JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here

# Optional: only allow GET/HEAD for jira_platform_request and jira_agile_request
# JIRA_MCP_HTTP_READ_ONLY=true

# Optional: max JSON characters for generic request tools (default 500000)
# JIRA_MCP_MAX_RESPONSE_CHARS=500000
